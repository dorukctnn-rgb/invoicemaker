<script>
function calc() {
  const amount = parseFloat(document.getElementById('calcAmount').value) || 0;
  const rate = parseFloat(document.getElementById('calcRate').value);
  const vatAmount = amount * (rate / 100);
  const total = amount + vatAmount;
  const fmt = n => 'GBP ' + n.toLocaleString('en-GB', {minimumFractionDigits:2, maximumFractionDigits:2});
  document.getElementById('resNet').textContent = fmt(amount);
  document.getElementById('resVat').textContent = fmt(vatAmount);
  document.getElementById('resTotal').textContent = fmt(total);
  document.getElementById('rateLabel').textContent = rate === 0 ? 'VAT (0% - zero-rated)' : 'VAT (' + rate + '%)';
}
function toggleFaq(el) {
  el.classList.toggle('open');
  const span = el.querySelector('h4 span');
  span.textContent = el.classList.contains('open') ? '\u2212' : '+';
}
calc();
</script>

