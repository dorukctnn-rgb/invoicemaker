<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Activate PRO — InvoiceMaker</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:#f8fafc;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
.card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:40px;max-width:420px;width:100%;text-align:center}
.logo{font-weight:700;font-size:20px;margin-bottom:28px}.logo span{color:#2563eb}
h1{font-size:22px;font-weight:700;margin-bottom:8px}
p{color:#64748b;font-size:14px;line-height:1.6;margin-bottom:22px}
label{font-size:11px;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:.4px;display:block;text-align:left;margin-bottom:5px}
input{width:100%;border:1px solid #e2e8f0;border-radius:8px;padding:11px 14px;font-size:14px;font-family:'Inter',sans-serif;outline:none;margin-bottom:14px}
input:focus{border-color:#2563eb;box-shadow:0 0 0 3px rgba(37,99,235,.1)}
button{width:100%;padding:12px;background:#2563eb;border:none;border-radius:8px;color:#fff;font-size:15px;font-weight:600;cursor:pointer}
button:hover{background:#1d4ed8}
.msg{margin-top:14px;padding:11px 14px;border-radius:8px;font-size:13px;font-weight:500;display:none}
.ok{background:#dcfce7;color:#15803d}
.err{background:#fee2e2;color:#dc2626}
.back{display:inline-block;margin-top:18px;color:#64748b;font-size:13px}
</style>
</head>
<body>
<div class="card">
  <div class="logo">Invoice<span>Maker</span></div>
  <h1>Activate PRO</h1>
  <p>Enter the email you used to purchase on Gumroad. PRO access activates instantly.</p>
  <label>Purchase email</label>
  <input type="email" id="em" placeholder="you@email.com">
  <button onclick="act()">Activate PRO</button>
  <div class="msg" id="msg"></div>
  <a href="/" class="back">Back to invoice generator</a>
</div>
<script>
async function act(){
  const em=document.getElementById('em').value.trim();
  const msg=document.getElementById('msg');
  if(!em){msg.className='msg err';msg.style.display='block';msg.textContent='Please enter your email.';return;}
  const r=await fetch('/activate-pro',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:em})});
  const data=await r.json();
  if(data.success){msg.className='msg ok';msg.style.display='block';msg.textContent='PRO activated! Redirecting...';setTimeout(()=>window.location.href='/',1500);}
  else{msg.className='msg err';msg.style.display='block';msg.textContent=data.message||'Email not found.';}
}
</script>
</body>
</html>
