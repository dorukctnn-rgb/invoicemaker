<script>
const SYMBOLS = {
  USD:'$', GBP:'£', EUR:'€', CAD:'CA$', AUD:'A$', INR:'₹',
  AED:'د.إ', SGD:'S$', TRY:'₺', JPY:'¥', CHF:'CHF',
  SEK:'kr', NOK:'kr', DKK:'kr', NZD:'NZ$', ZAR:'R',
  BRL:'R$', MXN:'Mex$'
};

function $(id) { return document.getElementById(id); }
function symbol() { return SYMBOLS[$('currency').value] || '$'; }
function fmt(n) { return symbol() + (Number(n) || 0).toFixed(2); }

function updatePreview() {
  $('pvNum').textContent = 'Receipt #' + ($('receiptNumber').value || '');
  $('pvDate').textContent = $('receiptDate').value || '';
  $('pvTenant').textContent = $('tenantName').value || '—';
  $('pvLandlord').textContent = $('landlordName').value || '—';
  $('pvAddress').textContent = $('propertyAddress').value || '—';
  const from = $('periodFrom').value;
  const to = $('periodTo').value;
  $('pvPeriod').textContent = (from && to) ? `${from} to ${to}` : '—';
  $('pvAmount').textContent = fmt($('amount').value);
  $('pvMethod').textContent = $('paymentMethod').value;
}

document.addEventListener('DOMContentLoaded', () => {
  const today = new Date().toISOString().slice(0, 10);
  const monthStart = today.slice(0, 8) + '01';
  const next = new Date();
  next.setMonth(next.getMonth() + 1);
  const monthEnd = next.toISOString().slice(0, 8) + '01';

  $('receiptDate').value = today;
  $('periodFrom').value = monthStart;
  $('periodTo').value = monthEnd;

  document.querySelectorAll('input, select, textarea').forEach(el => {
    el.addEventListener('input', updatePreview);
  });

  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => q.parentElement.classList.toggle('open'));
  });

  $('downloadBtn').addEventListener('click', async () => {
    const btn = $('downloadBtn');
    btn.disabled = true;
    btn.textContent = 'Generating PDF...';

    const payload = {
      tenantName: $('tenantName').value,
      landlordName: $('landlordName').value,
      propertyAddress: $('propertyAddress').value,
      receiptNumber: $('receiptNumber').value,
      receiptDate: $('receiptDate').value,
      periodFrom: $('periodFrom').value,
      periodTo: $('periodTo').value,
      amount: parseFloat($('amount').value) || 0,
      currency: $('currency').value,
      paymentMethod: $('paymentMethod').value,
      isPro: false
    };

    try {
      const res = await fetch('/api/rent-receipt-pdf', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      if (!res.ok) throw new Error('PDF generation failed');
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `rent-receipt-${payload.receiptNumber || 'draft'}.pdf`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    } catch (err) {
      alert('Could not generate PDF: ' + err.message);
    } finally {
      btn.disabled = false;
      btn.textContent = '⬇ Download Free PDF Receipt';
    }
  });

  updatePreview();
});
</script>

