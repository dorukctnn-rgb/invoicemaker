<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Invoicing Guides & Resources | GetInvoiceMaker Blog</title>
<meta name="description" content="Free invoicing guides, templates and tips for freelancers and small businesses. Learn how to invoice professionally, handle VAT, and get paid faster.">
<link rel="canonical" href="<%= siteUrl %>/blog">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:#f8fafc;color:#0f172a}
a{color:#2563eb;text-decoration:none}
nav{background:#fff;border-bottom:1px solid #e2e8f0;padding:0 32px;display:flex;justify-content:space-between;align-items:center;height:60px;position:sticky;top:0;z-index:100}
.logo{font-weight:700;font-size:18px}.logo span{color:#2563eb}
.nav-r{display:flex;gap:8px;align-items:center}
.nav-r a{color:#64748b;font-size:13px;padding:6px 12px;border-radius:6px}
.nav-r a:hover{background:#f1f5f9}
.btn-blue{background:#2563eb;color:#fff;border:none;padding:8px 18px;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer}
.hero{background:#fff;border-bottom:1px solid #e2e8f0;padding:48px 24px 40px;text-align:center}
.hero h1{font-size:clamp(24px,4vw,36px);font-weight:700;margin-bottom:12px}
.hero p{color:#475569;font-size:15px;max-width:520px;margin:0 auto}
.container{max-width:960px;margin:0 auto;padding:40px 20px}
.section-title{font-size:20px;font-weight:700;margin-bottom:24px;color:#0f172a}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px}
@media(max-width:700px){.blog-grid{grid-template-columns:1fr}}
.blog-card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:20px;transition:box-shadow .15s}
.blog-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.08)}
.tag{font-size:10px;font-weight:600;color:#2563eb;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.blog-card h2{font-size:14px;font-weight:600;line-height:1.5;margin-bottom:8px;color:#0f172a}
.blog-card p{font-size:12px;color:#64748b;line-height:1.5;margin-bottom:12px}
.meta{font-size:11px;color:#94a3b8;display:flex;gap:12px}
.howto-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:48px}
@media(max-width:700px){.howto-grid{grid-template-columns:1fr}}
.howto-card{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:16px;display:flex;align-items:center;gap:12px}
.howto-card:hover{border-color:#2563eb}
.howto-icon{width:32px;height:32px;background:#eff6ff;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.howto-card h3{font-size:13px;font-weight:600;color:#0f172a;margin-bottom:3px}
.howto-card p{font-size:11px;color:#64748b;line-height:1.4}
footer{background:#0f172a;color:#94a3b8;padding:28px 20px;text-align:center;font-size:12px}
footer a{color:#64748b;margin:0 10px}
footer a:hover{color:#fff}
</style>
</head>
<body>
<nav>
  <a href="/"><div class="logo">Invoice<span>Maker</span></div></a>
  <div class="nav-r">
    <a href="/">Tool</a>
    <a href="/blog">Blog</a>
    <a href="/#pricing"><button class="btn-blue">Get PRO</button></a>
  </div>
</nav>
<section class="hero">
  <h1>Invoicing Guides & Resources</h1>
  <p>Free guides, templates and tips to help freelancers and small businesses invoice professionally and get paid faster.</p>
</section>
<div class="container">
  <div class="section-title">Latest guides</div>
  <div class="blog-grid">
    <% posts.forEach(function(post) { %>
    <a href="/blog/<%= post.slug %>" class="blog-card" style="display:block">
      <div class="tag"><%= post.category %></div>
      <h2><%= post.title %></h2>
      <p><%= post.desc.substring(0,100) %>...</p>
      <div class="meta"><span><%= post.date %></span><span><%= post.readTime %></span></div>
    </a>
    <% }) %>
  </div>
  <div class="section-title">How-to guides</div>
  <div class="howto-grid">
    <% howTo.forEach(function(page) { %>
    <a href="/<%= page.slug %>" class="howto-card" style="display:block">
      <div class="howto-icon">&#128196;</div>
      <div>
        <h3><%= page.title %></h3>
        <p><%= page.desc.substring(0,80) %>...</p>
      </div>
    </a>
    <% }) %>
  </div>
</div>
<footer>
  <a href="/">Home</a><a href="/blog">Blog</a><a href="/#pricing">Pricing</a>
  <p style="margin-top:12px">&#169; 2026 GetInvoiceMaker — Free Invoice Generator</p>
</footer>
</body>
</html>
