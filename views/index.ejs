<script>
let color='#2563eb';
function setColor(el){document.querySelectorAll('.cdot').forEach(d=>d.classList.remove('on'));el.classList.add('on');color=el.dataset.c;up();}
function sym(){return document.getElementById('currency').value.split('|')[1]||'$';}
function items(){
  const rows=document.querySelectorAll('.ir');const r=[];
  rows.forEach(row=>{const ins=row.querySelectorAll('input');if(ins.length>=3){const d=ins[0].value,q=parseFloat(ins[1].value)||0,ra=parseFloat(ins[2].value)||0,t=q*ra;row.querySelector('.lt').textContent=sym()+t.toFixed(2);r.push({desc:d,qty:q,rate:ra});}});
  return r;
}
function calcs(its){
  const s=sym();const sub=its.reduce((a,i)=>a+i.qty*i.rate,0);
  const tr=parseFloat(document.getElementById('taxRate').value)||0;
  const tl=document.getElementById('taxLabel').value||'Tax';
  const ta=sub*tr/100;const tot=sub+ta;
  document.getElementById('sub').textContent=s+sub.toFixed(2);
  document.getElementById('tot').textContent=s+tot.toFixed(2);
  const trow=document.getElementById('taxrow');
  if(tr>0){trow.style.display='flex';document.getElementById('tlabel').textContent=tl+' ('+tr+'%)';document.getElementById('taxamt').textContent=s+ta.toFixed(2);}
  else trow.style.display='none';
  return{sub,ta,tot,tr,tl};
}
function buildHTML(d){
  const wm = d.isPro ? '' : '<div style="position:fixed;bottom:20px;right:20px;background:rgba(37,99,235,0.08);border:1px solid rgba(37,99,235,0.2);padding:6px 14px;border-radius:50px;font-size:11px;color:#2563eb;font-weight:600">Created with GetInvoiceMaker.com</div>';
  const s=d.symbol||'$';
  const rows=(d.items||[]).map(i=>'<tr><td style="padding:8px 0;border-bottom:1px solid #f1f5f9;font-size:13px">'+(i.desc||'&nbsp;')+'</td><td style="padding:8px;border-bottom:1px solid #f1f5f9;text-align:center;font-size:13px">'+i.qty+'</td><td style="padding:8px;border-bottom:1px solid #f1f5f9;text-align:right;font-size:13px">'+s+parseFloat(i.rate).toFixed(2)+'</td><td style="padding:8px 0 8px 8px;border-bottom:1px solid #f1f5f9;text-align:right;font-size:13px;font-weight:600">'+s+(i.qty*i.rate).toFixed(2)+'</td></tr>').join('');
  const tl=d.tr>0?'<div style="display:flex;justify-content:space-between;padding:4px 0;font-size:12px;color:#64748b"><span>'+(d.tl||'Tax')+' ('+d.tr+'%)</span><span>'+s+(d.ta||0).toFixed(2)+'</span></div>':'';
  return '<!DOCTYPE html><html><head><meta charset="UTF-8"><style>body{font-family:Arial,sans-serif;color:#0f172a;margin:0;padding:22px;font-size:13px}*{box-sizing:border-box}</style></head><body><div style="display:flex;justify-content:space-between;margin-bottom:26px"><div><div style="font-size:26px;font-weight:700;color:'+d.color+'">INVOICE</div><div style="color:#94a3b8;font-size:11px;margin-top:2px">#'+(d.invNum||'001')+'</div></div><div style="text-align:right"><div style="font-weight:700;font-size:15px">'+(d.fromName||'Your Company')+'</div><div style="color:#64748b;font-size:11px">'+(d.fromEmail||'')+'</div><div style="color:#64748b;font-size:11px;white-space:pre-line">'+(d.fromAddress||'').replace(/\n/g,"<br>")+'</div></div></div><div style="display:flex;justify-content:space-between;margin-bottom:22px;padding-bottom:16px;border-bottom:2px solid '+d.color+'"><div><div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Bill To</div><div style="font-weight:600;font-size:14px">'+(d.toName||'Client Name')+'</div><div style="color:#64748b;font-size:11px">'+(d.toEmail||'')+'</div><div style="color:#64748b;font-size:11px;white-space:pre-line">'+(d.toAddress||'').replace(/\n/g,"<br>")+'</div></div><div style="text-align:right"><div style="margin-bottom:8px"><div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px">Issue Date</div><div style="font-weight:600;font-size:12px">'+(d.issueDate||'')+'</div></div><div><div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px">Due Date</div><div style="font-weight:600;font-size:12px">'+(d.dueDate||'')+'</div></div></div></div><table style="width:100%;border-collapse:collapse;margin-bottom:16px"><thead><tr style="background:'+d.color+';color:#fff"><th style="padding:9px 0;text-align:left;font-size:10px;letter-spacing:.5px;font-weight:700">DESCRIPTION</th><th style="padding:9px 8px;text-align:center;font-size:10px;font-weight:700">QTY</th><th style="padding:9px 8px;text-align:right;font-size:10px;font-weight:700">RATE</th><th style="padding:9px 0 9px 8px;text-align:right;font-size:10px;font-weight:700">AMOUNT</th></tr></thead><tbody>'+rows+'</tbody></table><div style="display:flex;justify-content:flex-end;margin-bottom:20px"><div style="min-width:200px"><div style="display:flex;justify-content:space-between;padding:4px 0;font-size:12px;color:#64748b"><span>Subtotal</span><span>'+s+(d.sub||0).toFixed(2)+'</span></div>'+tl+'<div style="display:flex;justify-content:space-between;padding:8px 0 4px;font-size:16px;font-weight:700;border-top:2px solid '+d.color+';margin-top:4px"><span>Total Due</span><span style="color:'+d.color+'">'+s+(d.tot||0).toFixed(2)+'</span></div></div></div>'+(d.notes?'<div style="background:#f8fafc;border-left:4px solid '+d.color+';padding:10px 14px;border-radius:0 6px 6px 0"><div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Notes &amp; Payment Info</div><div style="font-size:12px;color:#475569;line-height:1.6">'+d.notes+'</div></div>':'')+wm+'</body></html>';
}
function up(){
  const its=items();const{sub,ta,tot,tr,tl}=calcs(its);const s=sym();
  const d={fromName:document.getElementById('fromName').value,fromEmail:document.getElementById('fromEmail').value,fromAddress:document.getElementById('fromAddress').value,toName:document.getElementById('toName').value,toEmail:document.getElementById('toEmail').value,toAddress:document.getElementById('toAddress').value,invNum:document.getElementById('invNum').value,issueDate:document.getElementById('issueDate').value,dueDate:document.getElementById('dueDate').value,notes:document.getElementById('notes').value,tr,tl,ta,sub,tot,items:its,color,symbol:s,isPro:false};
  document.getElementById('pframe').srcdoc=buildHTML(d);
}
function addItem(){
  const c=document.getElementById('items');
  const d=document.createElement('div');d.className='ir';
  d.innerHTML='<input type="text" placeholder="Service or product" oninput="up()"><input type="number" value="1" min="0" step="any" oninput="up()"><input type="number" value="0" min="0" step="any" oninput="up()"><div class="lt">$0.00</div><button class="del" onclick="delItem(this)" title="Remove">&#215;</button>';
  c.appendChild(d);up();
}
function delItem(btn){if(document.querySelectorAll('.ir').length>1){btn.parentElement.remove();up();}}
function toggleFaq(el){el.classList.toggle('open');const span=el.querySelector('h3 span');span.textContent=el.classList.contains('open')?'−':'+';}
async function dlPDF(){
  const btn=document.getElementById('pbtn');
  btn.textContent='Generating your PDF...';btn.disabled=true;
  const its=items();const{sub,ta,tot,tr,tl}=calcs(its);const s=sym();
  const payload={
    senderName:document.getElementById('fromName').value,
    senderEmail:document.getElementById('fromEmail').value,
    senderAddress:document.getElementById('fromAddress').value,
    clientName:document.getElementById('toName').value,
    clientEmail:document.getElementById('toEmail').value,
    clientAddress:document.getElementById('toAddress').value,
    invoiceNumber:document.getElementById('invNum').value,
    issueDate:document.getElementById('issueDate').value,
    dueDate:document.getElementById('dueDate').value,
    notes:document.getElementById('notes').value,
    taxRate:tr,
    taxLabel:tl,
    items:its.map(i=>({description:i.desc,qty:i.qty,rate:i.rate})),
    currency:document.getElementById('currency').value.split('|')[0],
    color:color,
    isPro:false
  };
  try{
    const res=await fetch('/api/pdf',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    if(!res.ok)throw new Error();
    const blob=await res.blob();const url=URL.createObjectURL(blob);
    const a=document.createElement('a');a.href=url;a.download='invoice-'+(payload.invoiceNumber||'001')+'.pdf';document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url);
    btn.innerHTML='&#8595; Download Free PDF Invoice';btn.disabled=false;
  }catch(e){btn.textContent='Error — please try again';btn.disabled=false;}
}
const t=new Date().toISOString().split('T')[0];
const d2=new Date(Date.now()+14*864e5).toISOString().split('T')[0];
document.getElementById('issueDate').value=t;
document.getElementById('dueDate').value=d2;
up();
</script>
</body>
</html>