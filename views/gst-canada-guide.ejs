<script>
function calc() {
  const amount = parseFloat(document.getElementById('calcAmount').value) || 0;
  const provinceData = document.getElementById('calcProvince').value.split('|');
  const taxType = provinceData[1];
  const totalRate = parseFloat(provinceData[2]);

  let gstAmount = 0, pstAmount = 0;

  if (taxType === 'GST') {
    gstAmount = amount * 0.05;
    document.getElementById('gstLine').querySelector('span').textContent = 'GST (5%)';
    document.getElementById('pstLine').style.display = 'none';
  } else if (taxType === 'HST') {
    gstAmount = amount * (totalRate / 100);
    document.getElementById('gstLine').querySelector('span').textContent = 'HST (' + totalRate + '%)';
    document.getElementById('pstLine').style.display = 'none';
  } else if (taxType === 'GST+PST') {
    gstAmount = amount * 0.05;
    const pstRate = totalRate - 5;
    pstAmount = amount * (pstRate / 100);
    document.getElementById('gstLine').querySelector('span').textContent = 'GST (5%)';
    document.getElementById('pstLine').style.display = 'flex';
    document.getElementById('pstLabel').textContent = 'PST (' + pstRate + '%)';
  } else if (taxType === 'GST+RST') {
    gstAmount = amount * 0.05;
    pstAmount = amount * 0.07;
    document.getElementById('gstLine').querySelector('span').textContent = 'GST (5%)';
    document.getElementById('pstLine').style.display = 'flex';
    document.getElementById('pstLabel').textContent = 'RST (7%)';
  } else if (taxType === 'GST+QST') {
    gstAmount = amount * 0.05;
    pstAmount = amount * 0.09975;
    document.getElementById('gstLine').querySelector('span').textContent = 'GST (5%)';
    document.getElementById('pstLine').style.display = 'flex';
    document.getElementById('pstLabel').textContent = 'QST (9.975%)';
  }

  const total = amount + gstAmount + pstAmount;
  const fmt = n => 'CAD ' + n.toLocaleString('en-CA', {minimumFractionDigits:2, maximumFractionDigits:2});

  document.getElementById('resSub').textContent = fmt(amount);
  document.getElementById('resGst').textContent = fmt(gstAmount);
  document.getElementById('resPst').textContent = fmt(pstAmount);
  document.getElementById('resTotal').textContent = fmt(total);
}

function toggleFaq(el) {
  el.classList.toggle('open');
  const span = el.querySelector('h4 span');
  span.textContent = el.classList.contains('open') ? '−' : '+';
}

calc();
</script>

