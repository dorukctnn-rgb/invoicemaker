<script>
function calc() {
  const amount = parseFloat(document.getElementById('calcAmount').value) || 0;
  const mode = document.getElementById('calcMode').value;
  let base = 0, gst = 0, total = 0;
  let l1 = 'GST-exclusive amount', l2 = 'GST (10%)', l3 = 'Total (GST-inclusive)';

  if (mode === 'add') {
    base = amount;
    gst = amount * 0.10;
    total = base + gst;
  } else if (mode === 'remove') {
    total = amount;
    gst = amount / 11;
    base = total - gst;
    l1 = 'Pre-GST amount';
    l2 = 'GST (10%, extracted)';
    l3 = 'GST-inclusive total (entered)';
  } else if (mode === 'gstfree') {
    base = amount;
    gst = 0;
    total = amount;
    l1 = 'Amount';
    l2 = 'GST (0% - GST-free)';
    l3 = 'Total';
  }

  const fmt = n => 'A$' + n.toLocaleString('en-AU', {minimumFractionDigits:2, maximumFractionDigits:2});
  document.getElementById('line1Label').textContent = l1;
  document.getElementById('line2Label').textContent = l2;
  document.getElementById('line3Label').textContent = l3;
  document.getElementById('resBase').textContent = fmt(base);
  document.getElementById('resGst').textContent = fmt(gst);
  document.getElementById('resTotal').textContent = fmt(total);
}

function toggleFaq(el) {
  el.classList.toggle('open');
  const span = el.querySelector('h4 span');
  span.textContent = el.classList.contains('open') ? '\u2212' : '+';
}

calc();
</script>

